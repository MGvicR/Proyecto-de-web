Options -Indexes

<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 64M
    php_value max_file_uploads 30
</IfModule>

<IfModule mod_php8.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 64M
    php_value max_file_uploads 30
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>
